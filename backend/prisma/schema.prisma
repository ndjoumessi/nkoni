// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  PRESIDENT
  SECRETAIRE
  TRESORIERE
  COMMISSAIRE_COMPTES
  GUIDE_RELIGIEUX
  MEMBRE_SIMPLE
}

enum StatutMembre {
  ACTIF
  INACTIF
  DECEDE
}

enum ModeVersement {
  ESPECES
  TIERS
  AUTRE
}

enum StatutContribution {
  A_JOUR
  PARTIEL
  NON_A_JOUR
}

model Utilisateur {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  role         Role
  actif        Boolean  @default(true)
  membre       Membre?  @relation("CompteMembre")
  // V2 (§4.4) — conflits déclarés / suivis par ce compte.
  conflitsAuteur      Conflit[] @relation("ConflitAuteur")
  conflitsResponsable Conflit[] @relation("ConflitResponsableSuivi")
  documentsTeleverses Document[] @relation("DocumentTeleversePar") // V2 §5
  auditsActeur        AuditLog[] @relation("AuditActeur") // V2 §5 — écritures tracées
  notifications       Notification[] @relation("NotificationDestinataire") // V2 §5 — notifs reçues
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model BrancheFamiliale {
  id          String   @id @default(uuid())
  nom         String
  description String?
  membres     Membre[]
  createdAt   DateTime @default(now())
}

model Membre {
  id                  String            @id @default(uuid())
  nom                 String
  prenom              String
  sexe                String?
  dateNaissance       DateTime?
  fonctionSociale     String?
  statut              StatutMembre      @default(ACTIF)
  telephone           String?
  adresse             String?
  brancheId           String?
  branche             BrancheFamiliale? @relation(fields: [brancheId], references: [id])
  chefSousFamilleId   String?
  chefSousFamille     Membre?           @relation("ChefSousFamille", fields: [chefSousFamilleId], references: [id])
  membresRattaches    Membre[]          @relation("ChefSousFamille")
  anneeAdhesion       Int               // année à partir de laquelle la contribution est attendue
  anneeFinContribution Int?             // renseignée automatiquement si statut = DECEDE ou INACTIF
  dateDeces           DateTime?
  compteUtilisateurId String?           @unique
  compteUtilisateur   Utilisateur?      @relation("CompteMembre", fields: [compteUtilisateurId], references: [id])
  contributions       Contribution[]
  affectationsFonction AffectationFonction[] // V1.1 — nominations (actives + passées)
  conflitsConcernes   Conflit[]         @relation("ConflitMembresConcernes") // V2 §4.4
  commemorationsConcernees Commemoration[] @relation("CommemorationMembresConcernes") // V2
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
}

model BaremeAnnuel {
  id             String @id @default(uuid())
  annee          Int    @unique
  montantAttendu Int    // en FCFA, uniforme pour tous les membres actifs cette année-là
  createdAt      DateTime @default(now())
}

model Contribution {
  id              String   @id @default(uuid())
  membreId        String
  membre          Membre   @relation(fields: [membreId], references: [id])
  annee           Int
  montantAttendu  Int      // copié du BaremeAnnuel au moment de la création (historisation)
  montantVerse    Int      @default(0) // somme dénormalisée des Versement.montant
  montantValorise Int      @default(0) // = montantVerse par défaut, modifiable uniquement par un Équilibrage
  versements      Versement[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([membreId, annee])
}

model Versement {
  id              String        @id @default(uuid())
  contributionId  String
  contribution    Contribution  @relation(fields: [contributionId], references: [id])
  montant         Int
  dateVersement   DateTime
  mode            ModeVersement
  receptionnaireId String?      // FK Utilisateur (généralement la trésorière)
  note            String?
  createdAt       DateTime      @default(now())
}

model EquilibrageContribution {
  id             String   @id @default(uuid())
  membreId       String
  anneeDebut     Int
  anneeFin       Int
  totalPeriode   Int      // total conservé, doit être identique avant/après
  auteurId       String   // FK Utilisateur
  dateApplication DateTime @default(now())
  details        EquilibrageDetail[]
}

model EquilibrageDetail {
  id             String   @id @default(uuid())
  equilibrageId  String
  equilibrage    EquilibrageContribution @relation(fields: [equilibrageId], references: [id])
  annee          Int
  montantAvant   Int
  montantApres   Int
}

model Recu {
  id             String   @id @default(uuid())
  versementId    String
  numero         String   @unique // ex. NKONI-2025-000123
  genereParId    String   // FK Utilisateur
  dateGeneration DateTime @default(now())
  urlPdf         String?
}

// ---------------------------------------------------------------------------
// Entités hors périmètre MVP (§3.2) — squelettes vides.
// Déclarés uniquement pour éviter une migration lourde en V1.1/V2.
// AUCUNE logique métier, AUCUN impact sur les routes/services du MVP.
// Les relations vers les entités MVP (Membre, Utilisateur) seront ajoutées
// au moment du développement de chaque module.
// ---------------------------------------------------------------------------

enum NiveauConfidentialite {
  PUBLIC
  BUREAU
  CONFIDENTIEL
}

// ---------------------------------------------------------------------------
// V1.1 (§5) — Réunions, Ordre du jour, Résolutions.
// Résolutions PUREMENT DOCUMENTAIRES : aucun effet mécanique sur le reste du
// système (cf. resolution.service.ts). Choix arbitré, pas un oubli.
// ---------------------------------------------------------------------------

enum TypeReunion {
  ORDINAIRE
  EXTRAORDINAIRE
}

enum StatutReunion {
  PLANIFIEE
  TENUE
  ANNULEE
}

enum StatutResolution {
  ADOPTEE
  REJETEE
  REPORTEE
}

model Reunion {
  id                String             @id @default(uuid())
  date              DateTime
  lieu              String
  type              TypeReunion        @default(ORDINAIRE)
  statut            StatutReunion      @default(PLANIFIEE)
  compteRenduTexte  String?            // texte libre ; pas de module fichier séparé pour l'instant
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  pointsOrdreDuJour PointOrdreDuJour[]
  resolutions       Resolution[]
}

model PointOrdreDuJour {
  id          String       @id @default(uuid())
  reunionId   String
  reunion     Reunion      @relation(fields: [reunionId], references: [id], onDelete: Cascade)
  titre       String
  ordre       Int          // position d'affichage dans l'ordre du jour
  notes       String?
  createdAt   DateTime     @default(now())
  resolutions Resolution[]

  @@index([reunionId, ordre])
}

model Resolution {
  id                 String            @id @default(uuid())
  reunionId          String
  reunion            Reunion           @relation(fields: [reunionId], references: [id], onDelete: Cascade)
  // Rattachement optionnel à un point d'ordre du jour (de la MÊME réunion — contrôlé en service).
  // Si le point est supprimé, la résolution est conservée (pointOrdreDuJourId → NULL).
  pointOrdreDuJourId String?
  pointOrdreDuJour   PointOrdreDuJour? @relation(fields: [pointOrdreDuJourId], references: [id], onDelete: SetNull)
  texte              String
  statut             StatutResolution  @default(ADOPTEE)
  dateVote           DateTime?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
}

// ---------------------------------------------------------------------------
// V1.1 (§5) — Fonctions/organes + historique des nominations.
//
// Règle métier centrale : MONO-TITULAIRE avec clôture automatique. Une
// FonctionFamiliale n'a qu'UNE SEULE AffectationFonction active (dateFin = null)
// à la fois. Nommer un nouveau titulaire clôture automatiquement l'affectation
// active précédente, dans une transaction (cf. affectation.service.ts).
//
// Convention d'intervalle (documentée, tranchée) : bornes SEMI-OUVERTES
// [dateDebut, dateFin). La clôture pose dateFin de l'ancienne affectation =
// dateDebut de la nouvelle (pas « la veille ») : pas de trou ni de recouvrement,
// et « qui occupe la fonction à l'instant T » a une réponse unique.
//
// L'historique est IMMUABLE : aucune suppression physique d'une affectation
// clôturée (pas d'endpoint update/delete côté affectation ; seule la création
// écrit, en clôturant la précédente). Un membre peut cumuler plusieurs fonctions.
// ---------------------------------------------------------------------------

model FonctionFamiliale {
  id           String                @id @default(uuid())
  nom          String                @unique
  description  String?
  createdAt    DateTime              @default(now())
  // Suppression d'une fonction → cascade sur son historique d'affectations
  // (cohérent avec Reunion → points ; le CRUD complet est réservé ADMIN/PRESIDENT).
  affectations AffectationFonction[]
}

model AffectationFonction {
  id         String            @id @default(uuid())
  fonctionId String
  fonction   FonctionFamiliale @relation(fields: [fonctionId], references: [id], onDelete: Cascade)
  membreId   String
  membre     Membre            @relation(fields: [membreId], references: [id])
  dateDebut  DateTime
  dateFin    DateTime? // null = affectation active (titulaire en cours)
  notes      String?
  createdAt  DateTime          @default(now())

  // Recherche de l'affectation active d'une fonction (where fonctionId, dateFin=null).
  @@index([fonctionId, dateFin])
  // Historique par membre (« quelles fonctions a occupé ce membre »).
  @@index([membreId])
}

model EvenementFamilial {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
}

// ---------------------------------------------------------------------------
// V2 (§4.4) — Conflits familiaux. Module SENSIBLE : la visibilité d'un conflit
// dépend de son niveauConfidentialite ET de l'identité/rôle du demandeur. La règle
// d'accès est une fonction pure (peutVoirConflit, cf. conflit.service.ts), source
// de vérité unique pour la liste filtrée ET pour GET /conflits/:id.
//   - PUBLIC       : tout utilisateur authentifié
//   - BUREAU       : ADMIN, PRESIDENT, SECRETAIRE
//   - CONFIDENTIEL : auteur, responsable de suivi désigné, ADMIN uniquement
// Le responsable de suivi n'est pertinent que pour CONFIDENTIEL, désigné à la
// création. Pas de suppression (un conflit clos reste dans l'historique).
// ---------------------------------------------------------------------------

enum StatutConflit {
  OUVERT
  EN_COURS
  RESOLU
  CLOS
}

model Conflit {
  id                    String                @id @default(uuid())
  titre                 String
  description           String
  niveauConfidentialite NiveauConfidentialite
  statut                StatutConflit         @default(OUVERT)
  auteurId              String
  auteur                Utilisateur           @relation("ConflitAuteur", fields: [auteurId], references: [id])
  // Optionnel ; pertinent seulement si niveauConfidentialite = CONFIDENTIEL.
  responsableSuiviId    String?
  responsableSuivi      Utilisateur?          @relation("ConflitResponsableSuivi", fields: [responsableSuiviId], references: [id])
  membresConcernes      Membre[]              @relation("ConflitMembresConcernes")
  dateOuverture         DateTime              @default(now())
  dateResolution        DateTime?
  notes                 String? // suivi / résolution
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  @@index([niveauConfidentialite])
  @@index([auteurId])
  @@index([responsableSuiviId])
}

// ---------------------------------------------------------------------------
// V2 — Commémorations / cérémonies. Domaine du GUIDE_RELIGIEUX (+ ADMIN) : premier
// module où ce rôle obtient des droits (CRUD). Le bureau (PRESIDENT/SECRETAIRE) peut
// créer/modifier (organisation) ; les autres rôles sont en lecture seule.
// Une commémoration peut concerner 0, 1 ou plusieurs membres (défunts honorés).
// ---------------------------------------------------------------------------

enum TypeCommemoration {
  COMMEMORATION
  CEREMONIE
}

enum StatutCommemoration {
  PLANIFIEE
  TENUE
  ANNULEE
}

model Commemoration {
  id               String              @id @default(uuid())
  titre            String
  type             TypeCommemoration   @default(COMMEMORATION)
  date             DateTime
  lieu             String?
  description      String?
  statut           StatutCommemoration @default(PLANIFIEE)
  membresConcernes Membre[]            @relation("CommemorationMembresConcernes")
  notes            String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@index([date])
}

// ---------------------------------------------------------------------------
// V2 (§5) — Documents / archives (stockage Vercel Blob).
//
// SÉCURITÉ : la visibilité d'un Document HÉRITE de celle de son entité parente
// (jamais de règle propre au Document). Voir peutVoirDocument (document.service.ts) qui
// délègue à peutVoirConflit / lecture Membre / Réunion / Commémoration selon entiteType.
// ---------------------------------------------------------------------------

enum EntiteDocument {
  MEMBRE
  REUNION
  CONFLIT
  COMMEMORATION
}

model Document {
  id                String         @id @default(uuid())
  nom               String
  description       String?
  url               String // URL du blob Vercel
  typeFichier       String // mime-type validé serveur (PDF/JPEG/PNG/DOCX)
  tailleOctets      Int
  entiteType        EntiteDocument
  // Référence POLYMORPHE : selon entiteType, entiteId pointe vers Membre | Reunion |
  // Conflit | Commemoration. PAS de FK Prisma possible (lien polymorphe) — l'intégrité
  // et le chargement du parent sont gérés en service (chargerParent / peutVoirDocument).
  entiteId          String
  televerseParId    String
  televersePar      Utilisateur    @relation("DocumentTeleversePar", fields: [televerseParId], references: [id])
  dateTeleversement DateTime       @default(now())
  createdAt         DateTime       @default(now())

  @@index([entiteType, entiteId])
  @@index([televerseParId])
}

// ---------------------------------------------------------------------------
// V2 (§5) — Audit trail transverse. Écrit AUTOMATIQUEMENT par une extension Prisma
// ($extends, cf. lib/audit-middleware.ts) sur les écritures create/update/delete de 6
// entités : Membre, Contribution, Versement, EquilibrageContribution, Utilisateur, Conflit.
// Snapshots avant/après en JSON — filtrés : jamais de passwordHash (Utilisateur), et pour
// Conflit uniquement des métadonnées NON sensibles (pas titre/description/notes). La lecture
// (GET /audit-log, ADMIN) applique en plus peutVoirConflit sur les entrées CONFLIT.
// ---------------------------------------------------------------------------

enum ActionAudit {
  CREATE
  UPDATE
  DELETE
}

model AuditLog {
  id           String       @id @default(uuid())
  entiteType   String // nom du modèle : 'Membre' | 'Contribution' | … | 'Conflit'
  entiteId     String
  action       ActionAudit
  acteurId     String? // null = écriture système (seed, migration…)
  acteur       Utilisateur? @relation("AuditActeur", fields: [acteurId], references: [id], onDelete: SetNull)
  donneesAvant Json? // snapshot avant (null pour CREATE) — passwordHash exclu
  donneesApres Json? // snapshot après (null pour DELETE) — passwordHash exclu
  dateAction   DateTime     @default(now())

  @@index([entiteType, entiteId])
  @@index([acteurId])
  @@index([dateAction])
}

// ---------------------------------------------------------------------------
// V2 (§5) — Notifications in-app. Canal interne uniquement (pas d'email).
// Périmètre initial : événements financiers (VERSEMENT_RECU, COTISATION_RETARD).
// Seuls les Utilisateur liés à un Membre peuvent en recevoir (cf. §4.5) — un membre
// sans compte ne notifie personne. `entiteType`/`entiteId` lient la notif à l'entité
// concernée (Versement / Contribution) sans FK dure (souple, comme AuditLog).
// ---------------------------------------------------------------------------

enum TypeNotification {
  VERSEMENT_RECU
  COTISATION_RETARD
}

model Notification {
  id             String           @id @default(uuid())
  destinataireId String
  destinataire   Utilisateur      @relation("NotificationDestinataire", fields: [destinataireId], references: [id], onDelete: Cascade)
  type           TypeNotification
  titre          String
  message        String
  entiteType     String? // ex. 'Versement' | 'Contribution' (pas de FK dure)
  entiteId       String?
  lu             Boolean          @default(false)
  dateCreation   DateTime         @default(now())
  dateLecture    DateTime? // renseignée au passage lu = true

  @@index([destinataireId, lu])
  @@index([destinataireId, type, dateCreation]) // pour l'anti-spam COTISATION_RETARD (< 7 j)
}
