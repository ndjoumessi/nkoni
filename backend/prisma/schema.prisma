// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  // Rôle PLATEFORME transverse (SaaS §2.3) — au-dessus des rôles d'organisation. Un
  // SUPER_ADMIN n'appartient à AUCUNE organisation (organisationId NULL, garanti par une
  // contrainte CHECK). Il gère les organisations clientes (liste, suspension) mais n'accède
  // pas aux données métier. Tous les rôles ci-dessous restent scopés à une organisation.
  SUPER_ADMIN
  ADMIN
  PRESIDENT
  SECRETAIRE
  TRESORIERE
  COMMISSAIRE_COMPTES
  GUIDE_RELIGIEUX
  MEMBRE_SIMPLE
}

enum StatutMembre {
  ACTIF
  INACTIF
  DECEDE
}

enum ModeVersement {
  ESPECES
  TIERS
  AUTRE
}

enum StatutContribution {
  A_JOUR
  PARTIEL
  NON_A_JOUR
}

// ===========================================================================
// SaaS multi-tenant (§2) — Organisation = racine de toute donnée métier.
//
// PHASE A (expand) : chaque modèle métier reçoit `organisationId` NULLABLE + un
// index. Le peuplement (backfill vers « WAMBA TCHOUPA ») se fait dans la migration
// de données suivante. PHASE C (fait) : extension d'isolation branchée + uniques
// par-organisation (BaremeAnnuel.annee, Recu.numero, FonctionFamiliale.nom → composites
// `@@unique([organisationId, champ])`). PHASE B (à venir) : passage `organisationId`
// NOT NULL après vérification 0 orphelin. Voir §9 (protocole de sécurité).
// ===========================================================================

enum Devise {
  FCFA
  EUR
  USD
  CAD
}

enum Langue {
  FR
  EN
}

// Forfait commercial de l'organisation (SaaS §3.1) — palier déterminant la limite de membres.
// GRATUIT est le défaut (rétro-compatible) ; PRO/ENTREPRISE lèvent le plafond. L'attribution
// est une action PLATEFORME réservée au SUPER_ADMIN (activation manuelle, pas de paiement).
enum Forfait {
  GRATUIT
  PRO
  ENTREPRISE
}

// Refresh tokens STATEFUL (sécurité M5) — rotation à chaque refresh + détection de réutilisation.
// Chaque token porte un `jti` unique et un `familleId` (constant sur toute une chaîne de rotations
// issue d'un même login). Au refresh : le token courant est révoqué et un nouveau est émis dans la
// MÊME famille ; si un token DÉJÀ révoqué est représenté (replay d'un token volé), TOUTE la famille
// est révoquée. NON scopé par organisation (accès en `runUnscoped`, comme le flux de refresh) →
// pas d'`organisationId`, donc hors `SCOPED_MODELS` (parité préservée).
model RefreshToken {
  id            String   @id @default(uuid())
  jti           String   @unique
  utilisateurId String
  familleId     String
  revoke        Boolean  @default(false)
  expiresAt     DateTime
  createdAt     DateTime @default(now())

  @@index([utilisateurId])
  @@index([familleId])
}

model Organisation {
  id           String   @id @default(uuid())
  nom          String
  devise       Devise // fixée à la création, immuable (§5)
  langueDefaut Langue   @default(FR)
  actif        Boolean  @default(true)
  // Forfait courant (SaaS §3.1). Défaut GRATUIT → les orgs existantes le deviennent au backfill.
  // Attribué par le SUPER_ADMIN (console plateforme) ; borne la limite de membres (cf. lib/forfait).
  forfait      Forfait  @default(GRATUIT)
  createdAt    DateTime @default(now())

  // Chef de l'organisation (dirigeant) — Membre désigné, ACTION MUTABLE réservée ADMIN/PRESIDENT
  // (distincte des paramètres immuables §5). ON DELETE SET NULL : supprimer le membre « déchef »
  // l'org sans la casser. `chefSurnom` = titre honorifique optionnel affiché à côté du nom.
  chefMembreId String?
  chef         Membre?  @relation("ChefOrganisation", fields: [chefMembreId], references: [id], onDelete: SetNull)
  chefSurnom   String?

  // Toutes les entités métier scopées (relations inverses).
  utilisateurs         Utilisateur[]
  branches             BrancheFamiliale[]
  membres              Membre[]
  baremes              BaremeAnnuel[]
  contributions        Contribution[]
  versements           Versement[]
  equilibrages         EquilibrageContribution[]
  equilibrageDetails   EquilibrageDetail[]
  recus                Recu[]
  reunions             Reunion[]
  pointsOrdreDuJour    PointOrdreDuJour[]
  resolutions          Resolution[]
  fonctions            FonctionFamiliale[]
  affectations         AffectationFonction[]
  evenements           EvenementFamilial[]
  conflits             Conflit[]
  conflitMembres       ConflitMembreConcerne[]
  commemorations       Commemoration[]
  commemorationMembres CommemorationMembreConcerne[]
  documents            Document[]
  auditLogs            AuditLog[]
  notifications        Notification[]
  depenses             Depense[]
  cagnottes            CagnotteEvenement[]
  donsCagnotte         DonCagnotte[]
  amendes              Amende[]
}

model Utilisateur {
  id                   String         @id @default(uuid())
  // SaaS : 1 utilisateur = 1 organisation en v1 (multi-org reporté V2). NULLABLE, mais
  // uniquement pour le SUPER_ADMIN transverse (§2.3) qui n'a pas d'organisation. L'invariant
  // « org NULL ⟺ role = SUPER_ADMIN » est garanti au niveau BASE par une contrainte CHECK
  // (migration saas_utilisateur_org_nullable_superadmin) : un utilisateur tenant a TOUJOURS
  // une org, un super-admin n'en a JAMAIS. Le typage Prisma ne peut pas exprimer ce lien
  // conditionnel — c'est la contrainte CHECK qui l'impose côté données.
  organisationId       String?
  organisation         Organisation?  @relation(fields: [organisationId], references: [id])
  email                String         @unique
  passwordHash         String
  role                 Role
  actif                Boolean        @default(true)
  // Époque de session (sécurité, audit M5) : incrémentée à tout changement/réinitialisation de mot
  // de passe. Le refresh token porte l'époque à laquelle il a été émis ; au refresh, une époque
  // périmée est refusée → TOUS les refresh tokens antérieurs (y compris volés) sont invalidés.
  sessionEpoch         Int            @default(0)
  // §4 i18n — préférence de langue PERSONNELLE (indépendante de `Organisation.langueDefaut`).
  // NULLABLE : null = préférence non exprimée → le backend retombe sur l'en-tête Accept-Language
  // puis FR (voir lib/i18n.ts). Un utilisateur la fixe via PATCH /auth/me/langue.
  langue               Langue?
  membre               Membre?        @relation("CompteMembre")
  // V2 (§4.4) — conflits déclarés / suivis par ce compte.
  conflitsAuteur       Conflit[]      @relation("ConflitAuteur")
  conflitsResponsable  Conflit[]      @relation("ConflitResponsableSuivi")
  documentsTeleverses  Document[]     @relation("DocumentTeleversePar") // V2 §5
  auditsActeur         AuditLog[]     @relation("AuditActeur") // V2 §5 — écritures tracées
  notifications        Notification[] @relation("NotificationDestinataire") // V2 §5 — notifs reçues
  depensesSaisies      Depense[]      @relation("DepenseSaisiPar") // Trésorerie — dépenses saisies
  depensesApprouvees   Depense[]      @relation("DepenseApprouvePar") // Trésorerie — dépenses approuvées/rejetées
  // Préférences de notification par type. null / clé absente = ACTIVÉ (défaut : tout activé,
  // rétrocompatible). Un type est désactivé seulement si explicitement { "TYPE": false }.
  notificationsActives Json?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  @@index([organisationId])
}

model BrancheFamiliale {
  id             String       @id @default(uuid())
  organisationId String
  organisation   Organisation @relation(fields: [organisationId], references: [id])
  nom            String
  description    String?
  membres        Membre[]
  createdAt      DateTime     @default(now())

  @@index([organisationId])
}

model Membre {
  id                       String                        @id @default(uuid())
  organisationId           String
  organisation             Organisation                  @relation(fields: [organisationId], references: [id])
  nom                      String
  prenom                   String
  sexe                     String?
  dateNaissance            DateTime?
  fonctionSociale          String?
  statut                   StatutMembre                  @default(ACTIF)
  telephone                String?
  adresse                  String?
  brancheId                String?
  branche                  BrancheFamiliale?             @relation(fields: [brancheId], references: [id])
  chefSousFamilleId        String?
  chefSousFamille          Membre?                       @relation("ChefSousFamille", fields: [chefSousFamilleId], references: [id])
  membresRattaches         Membre[]                      @relation("ChefSousFamille")
  anneeAdhesion            Int // année à partir de laquelle la contribution est attendue
  anneeFinContribution     Int? // renseignée automatiquement si statut = DECEDE ou INACTIF
  dateDeces                DateTime?
  // Photo du membre (§4.11) — Blob PRIVÉ (jamais exposé au client) : `photoBlobUrl` = URL interne
  // du store, servie via le proxy authentifié GET /membres/:id/photo. `photoMime` = type (jpeg/png).
  photoBlobUrl             String?
  photoMime                String?
  compteUtilisateurId      String?                       @unique
  compteUtilisateur        Utilisateur?                  @relation("CompteMembre", fields: [compteUtilisateurId], references: [id])
  contributions            Contribution[]
  affectationsFonction     AffectationFonction[] // V1.1 — nominations (actives + passées)
  conflitsConcernes        ConflitMembreConcerne[] // V2 §4.4 (join explicite, scopé org)
  commemorationsConcernees CommemorationMembreConcerne[] // V2 (join explicite, scopé org)
  depensesBeneficiaire     Depense[]                     @relation("DepenseBeneficiaire") // Trésorerie — aides reçues
  cagnottesBeneficiaire    CagnotteEvenement[]           @relation("CagnotteBeneficiaire") // Cagnottes dont il est bénéficiaire
  donsCagnotte             DonCagnotte[]                  @relation("DonCagnotteMembre") // Dons faits par ce membre
  amendes                  Amende[]                      @relation("AmendeMembre") // Amendes/pénalités du membre
  organisationsCommeChef   Organisation[]                @relation("ChefOrganisation") // Chef de l'organisation (inverse ; rare : 1)
  // Idempotence (§ PWA hors-ligne) : rejeu d'un « ajouter membre » saisi hors-ligne (uuid client).
  idempotenceKey           String?
  createdAt                DateTime                      @default(now())
  updatedAt                DateTime                      @updatedAt

  @@unique([organisationId, idempotenceKey])
  @@index([organisationId])
}

model BaremeAnnuel {
  id             String       @id @default(uuid())
  organisationId String
  organisation   Organisation @relation(fields: [organisationId], references: [id])
  // Unicité PAR ORGANISATION (SaaS §2.2) : une seule ligne par (org, année). La lecture par
  // année passe par un findFirst scopé (cf. contribution.service) — plus de findUnique global.
  annee          Int
  montantAttendu Int // en FCFA, uniforme pour tous les membres actifs cette année-là
  createdAt      DateTime     @default(now())

  // L'unique composite (org, annee) fournit déjà l'index pour les lectures par organisation.
  @@unique([organisationId, annee])
}

model Contribution {
  id              String       @id @default(uuid())
  organisationId  String
  organisation    Organisation @relation(fields: [organisationId], references: [id])
  membreId        String
  membre          Membre       @relation(fields: [membreId], references: [id])
  annee           Int
  montantAttendu  Int // copié du BaremeAnnuel au moment de la création (historisation)
  montantVerse    Int          @default(0) // somme dénormalisée des Versement.montant
  montantValorise Int          @default(0) // = montantVerse par défaut, modifiable uniquement par un Équilibrage
  versements      Versement[]
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@unique([membreId, annee])
  @@index([organisationId, annee])
}

model Versement {
  id               String        @id @default(uuid())
  organisationId   String
  organisation     Organisation  @relation(fields: [organisationId], references: [id])
  contributionId   String
  contribution     Contribution  @relation(fields: [contributionId], references: [id])
  montant          Int
  dateVersement    DateTime
  mode             ModeVersement
  receptionnaireId String? // FK Utilisateur (généralement la trésorière)
  note             String?
  // Idempotence (§ PWA hors-ligne) : clé client (uuid) unique PAR organisation. Un rejeu de la
  // même mutation (file de synchro) retrouve la ligne existante au lieu d'en créer une seconde.
  idempotenceKey   String?
  createdAt        DateTime      @default(now())
  // Reçu(s) émis. FK `onDelete: Restrict` côté Recu → un versement avec reçu ne peut pas être
  // supprimé (audit M3 : pas de reçu orphelin). Back-relation obligatoire côté Prisma.
  recus            Recu[]

  @@unique([organisationId, idempotenceKey])
  @@index([organisationId])
  @@index([contributionId])
}

model EquilibrageContribution {
  id              String              @id @default(uuid())
  organisationId  String
  organisation    Organisation        @relation(fields: [organisationId], references: [id])
  membreId        String
  anneeDebut      Int
  anneeFin        Int
  totalPeriode    Int // total conservé, doit être identique avant/après
  auteurId        String // FK Utilisateur
  dateApplication DateTime            @default(now())
  details         EquilibrageDetail[]

  @@index([organisationId])
}

model EquilibrageDetail {
  id             String                  @id @default(uuid())
  organisationId String
  organisation   Organisation            @relation(fields: [organisationId], references: [id])
  equilibrageId  String
  equilibrage    EquilibrageContribution @relation(fields: [equilibrageId], references: [id])
  annee          Int
  montantAvant   Int
  montantApres   Int

  @@index([organisationId])
}

model Recu {
  id             String       @id @default(uuid())
  organisationId String
  organisation   Organisation @relation(fields: [organisationId], references: [id])
  versementId    String
  // FK vers le Versement source. `onDelete: Restrict` : interdit de supprimer un versement dont
  // un reçu a été émis (preuve de paiement) → pas de reçu orphelin (audit M3).
  versement      Versement    @relation(fields: [versementId], references: [id], onDelete: Restrict)
  // Numérotation PROPRE À CHAQUE ORGANISATION (SaaS §2.2) : unicité (org, numero). La
  // génération séquentielle lit le dernier numéro via un findFirst scopé (recu.service).
  numero         String // ex. NKONI-2025-000123
  genereParId    String // FK Utilisateur
  dateGeneration DateTime     @default(now())
  urlPdf         String?

  @@unique([organisationId, numero])
  @@index([organisationId])
  @@index([versementId])
}

// ---------------------------------------------------------------------------
// Entités hors périmètre MVP (§3.2) — squelettes vides.
// Déclarés uniquement pour éviter une migration lourde en V1.1/V2.
// AUCUNE logique métier, AUCUN impact sur les routes/services du MVP.
// Les relations vers les entités MVP (Membre, Utilisateur) seront ajoutées
// au moment du développement de chaque module.
// ---------------------------------------------------------------------------

enum NiveauConfidentialite {
  PUBLIC
  BUREAU
  CONFIDENTIEL
}

// ---------------------------------------------------------------------------
// V1.1 (§5) — Réunions, Ordre du jour, Résolutions.
// Résolutions PUREMENT DOCUMENTAIRES : aucun effet mécanique sur le reste du
// système (cf. resolution.service.ts). Choix arbitré, pas un oubli.
// ---------------------------------------------------------------------------

enum TypeReunion {
  ORDINAIRE
  EXTRAORDINAIRE
}

enum StatutReunion {
  PLANIFIEE
  TENUE
  ANNULEE
}

enum StatutResolution {
  ADOPTEE
  REJETEE
  REPORTEE
}

model Reunion {
  id                String             @id @default(uuid())
  organisationId    String
  organisation      Organisation       @relation(fields: [organisationId], references: [id])
  date              DateTime
  lieu              String
  type              TypeReunion        @default(ORDINAIRE)
  statut            StatutReunion      @default(PLANIFIEE)
  compteRenduTexte  String? // texte libre ; pas de module fichier séparé pour l'instant
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  pointsOrdreDuJour PointOrdreDuJour[]
  resolutions       Resolution[]

  @@index([organisationId])
}

model PointOrdreDuJour {
  id             String       @id @default(uuid())
  organisationId String
  organisation   Organisation @relation(fields: [organisationId], references: [id])
  reunionId      String
  reunion        Reunion      @relation(fields: [reunionId], references: [id], onDelete: Cascade)
  titre          String
  ordre          Int // position d'affichage dans l'ordre du jour
  notes          String?
  createdAt      DateTime     @default(now())
  resolutions    Resolution[]

  @@index([reunionId, ordre])
  @@index([organisationId])
}

model Resolution {
  id                 String            @id @default(uuid())
  organisationId     String
  organisation       Organisation      @relation(fields: [organisationId], references: [id])
  reunionId          String
  reunion            Reunion           @relation(fields: [reunionId], references: [id], onDelete: Cascade)
  // Rattachement optionnel à un point d'ordre du jour (de la MÊME réunion — contrôlé en service).
  // Si le point est supprimé, la résolution est conservée (pointOrdreDuJourId → NULL).
  pointOrdreDuJourId String?
  pointOrdreDuJour   PointOrdreDuJour? @relation(fields: [pointOrdreDuJourId], references: [id], onDelete: SetNull)
  texte              String
  statut             StatutResolution  @default(ADOPTEE)
  dateVote           DateTime?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@index([organisationId])
}

// ---------------------------------------------------------------------------
// V1.1 (§5) — Fonctions/organes + historique des nominations.
//
// Règle métier centrale : MONO-TITULAIRE avec clôture automatique. Une
// FonctionFamiliale n'a qu'UNE SEULE AffectationFonction active (dateFin = null)
// à la fois. Nommer un nouveau titulaire clôture automatiquement l'affectation
// active précédente, dans une transaction (cf. affectation.service.ts).
//
// Convention d'intervalle (documentée, tranchée) : bornes SEMI-OUVERTES
// [dateDebut, dateFin). La clôture pose dateFin de l'ancienne affectation =
// dateDebut de la nouvelle (pas « la veille ») : pas de trou ni de recouvrement,
// et « qui occupe la fonction à l'instant T » a une réponse unique.
//
// L'historique est IMMUABLE : aucune suppression physique d'une affectation
// clôturée (pas d'endpoint update/delete côté affectation ; seule la création
// écrit, en clôturant la précédente). Un membre peut cumuler plusieurs fonctions.
// ---------------------------------------------------------------------------

model FonctionFamiliale {
  id             String                @id @default(uuid())
  organisationId String
  organisation   Organisation          @relation(fields: [organisationId], references: [id])
  // Nom de fonction unique PAR organisation (SaaS §2.2). Le P2002 sur cette contrainte est
  // mappé en 409 (FonctionNomDuplicateError) sans inspecter la cible → inchangé côté service.
  nom            String
  description    String?
  createdAt      DateTime              @default(now())
  // Suppression d'une fonction → cascade sur son historique d'affectations
  // (cohérent avec Reunion → points ; le CRUD complet est réservé ADMIN/PRESIDENT).
  affectations   AffectationFonction[]

  @@unique([organisationId, nom])
  @@index([organisationId])
}

model AffectationFonction {
  id             String            @id @default(uuid())
  organisationId String
  organisation   Organisation      @relation(fields: [organisationId], references: [id])
  fonctionId     String
  fonction       FonctionFamiliale @relation(fields: [fonctionId], references: [id], onDelete: Cascade)
  membreId       String
  membre         Membre            @relation(fields: [membreId], references: [id])
  dateDebut      DateTime
  dateFin        DateTime? // null = affectation active (titulaire en cours)
  notes          String?
  createdAt      DateTime          @default(now())

  // Recherche de l'affectation active d'une fonction (where fonctionId, dateFin=null).
  @@index([fonctionId, dateFin])
  // Historique par membre (« quelles fonctions a occupé ce membre »).
  @@index([membreId])
  @@index([organisationId])
}

model EvenementFamilial {
  id             String       @id @default(uuid())
  organisationId String
  organisation   Organisation @relation(fields: [organisationId], references: [id])
  createdAt      DateTime     @default(now())

  @@index([organisationId])
}

// ---------------------------------------------------------------------------
// V2 (§4.4) — Conflits familiaux. Module SENSIBLE : la visibilité d'un conflit
// dépend de son niveauConfidentialite ET de l'identité/rôle du demandeur. La règle
// d'accès est une fonction pure (peutVoirConflit, cf. conflit.service.ts), source
// de vérité unique pour la liste filtrée ET pour GET /conflits/:id.
//   - PUBLIC       : tout utilisateur authentifié
//   - BUREAU       : ADMIN, PRESIDENT, SECRETAIRE
//   - CONFIDENTIEL : auteur, responsable de suivi désigné, ADMIN uniquement
// Le responsable de suivi n'est pertinent que pour CONFIDENTIEL, désigné à la
// création. Pas de suppression (un conflit clos reste dans l'historique).
// ---------------------------------------------------------------------------

enum StatutConflit {
  OUVERT
  EN_COURS
  RESOLU
  CLOS
}

model Conflit {
  id                    String                  @id @default(uuid())
  organisationId        String
  organisation          Organisation            @relation(fields: [organisationId], references: [id])
  titre                 String
  description           String
  niveauConfidentialite NiveauConfidentialite
  statut                StatutConflit           @default(OUVERT)
  auteurId              String
  auteur                Utilisateur             @relation("ConflitAuteur", fields: [auteurId], references: [id])
  // Optionnel ; pertinent seulement si niveauConfidentialite = CONFIDENTIEL.
  responsableSuiviId    String?
  responsableSuivi      Utilisateur?            @relation("ConflitResponsableSuivi", fields: [responsableSuiviId], references: [id])
  membresConcernes      ConflitMembreConcerne[]
  dateOuverture         DateTime                @default(now())
  dateResolution        DateTime?
  notes                 String? // suivi / résolution
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt

  @@index([niveauConfidentialite])
  @@index([auteurId])
  @@index([responsableSuiviId])
  @@index([organisationId])
}

// Table de jointure EXPLICITE Conflit ↔ Membre (SaaS §2.2). Porte son propre
// `organisationId` pour rentrer dans le mécanisme d'isolation commun (extension Prisma) :
// toute écriture/lecture de lien passe par des opérations scopées, plutôt que par un
// M2M implicite non re-scopé. onDelete: Cascade → un conflit/membre supprimé retire ses liens.
model ConflitMembreConcerne {
  conflitId      String
  conflit        Conflit      @relation(fields: [conflitId], references: [id], onDelete: Cascade)
  membreId       String
  membre         Membre       @relation(fields: [membreId], references: [id], onDelete: Cascade)
  organisationId String
  organisation   Organisation @relation(fields: [organisationId], references: [id])

  @@id([conflitId, membreId])
  @@index([membreId])
  @@index([organisationId])
}

// ---------------------------------------------------------------------------
// V2 — Commémorations / cérémonies. Domaine du GUIDE_RELIGIEUX (+ ADMIN) : premier
// module où ce rôle obtient des droits (CRUD). Le bureau (PRESIDENT/SECRETAIRE) peut
// créer/modifier (organisation) ; les autres rôles sont en lecture seule.
// Une commémoration peut concerner 0, 1 ou plusieurs membres (défunts honorés).
// ---------------------------------------------------------------------------

enum TypeCommemoration {
  COMMEMORATION
  CEREMONIE
}

enum StatutCommemoration {
  PLANIFIEE
  TENUE
  ANNULEE
}

model Commemoration {
  id               String                        @id @default(uuid())
  organisationId   String
  organisation     Organisation                  @relation(fields: [organisationId], references: [id])
  titre            String
  type             TypeCommemoration             @default(COMMEMORATION)
  date             DateTime
  lieu             String?
  description      String?
  statut           StatutCommemoration           @default(PLANIFIEE)
  membresConcernes CommemorationMembreConcerne[]
  notes            String?
  createdAt        DateTime                      @default(now())
  updatedAt        DateTime                      @updatedAt

  @@index([date])
  @@index([organisationId])
}

// Table de jointure EXPLICITE Commémoration ↔ Membre (SaaS §2.2), même logique que
// ConflitMembreConcerne : `organisationId` propre → isolation via l'extension commune.
model CommemorationMembreConcerne {
  commemorationId String
  commemoration   Commemoration @relation(fields: [commemorationId], references: [id], onDelete: Cascade)
  membreId        String
  membre          Membre        @relation(fields: [membreId], references: [id], onDelete: Cascade)
  organisationId  String
  organisation    Organisation  @relation(fields: [organisationId], references: [id])

  @@id([commemorationId, membreId])
  @@index([membreId])
  @@index([organisationId])
}

// ---------------------------------------------------------------------------
// V2 (§5) — Documents / archives (stockage Vercel Blob).
//
// SÉCURITÉ : la visibilité d'un Document HÉRITE de celle de son entité parente
// (jamais de règle propre au Document). Voir peutVoirDocument (document.service.ts) qui
// délègue à peutVoirConflit / lecture Membre / Réunion / Commémoration selon entiteType.
// ---------------------------------------------------------------------------

enum EntiteDocument {
  MEMBRE
  REUNION
  CONFLIT
  COMMEMORATION
}

model Document {
  id                String         @id @default(uuid())
  organisationId    String
  organisation      Organisation   @relation(fields: [organisationId], references: [id])
  nom               String
  description       String?
  url               String // URL du blob Vercel
  typeFichier       String // mime-type validé serveur (PDF/JPEG/PNG/DOCX)
  tailleOctets      Int
  entiteType        EntiteDocument
  // Référence POLYMORPHE : selon entiteType, entiteId pointe vers Membre | Reunion |
  // Conflit | Commemoration. PAS de FK Prisma possible (lien polymorphe) — l'intégrité
  // et le chargement du parent sont gérés en service (chargerParent / peutVoirDocument).
  entiteId          String
  televerseParId    String
  televersePar      Utilisateur    @relation("DocumentTeleversePar", fields: [televerseParId], references: [id])
  dateTeleversement DateTime       @default(now())
  createdAt         DateTime       @default(now())

  @@index([entiteType, entiteId])
  @@index([televerseParId])
  @@index([organisationId])
}

// ---------------------------------------------------------------------------
// V2 (§5) — Audit trail transverse. Écrit AUTOMATIQUEMENT par une extension Prisma
// ($extends, cf. lib/audit-middleware.ts) sur les écritures create/update/delete de 6
// entités : Membre, Contribution, Versement, EquilibrageContribution, Utilisateur, Conflit.
// Snapshots avant/après en JSON — filtrés : jamais de passwordHash (Utilisateur), et pour
// Conflit uniquement des métadonnées NON sensibles (pas titre/description/notes). La lecture
// (GET /audit-log, ADMIN) applique en plus peutVoirConflit sur les entrées CONFLIT.
// ---------------------------------------------------------------------------

enum ActionAudit {
  CREATE
  UPDATE
  DELETE
}

model AuditLog {
  id             String       @id @default(uuid())
  organisationId String
  organisation   Organisation @relation(fields: [organisationId], references: [id])
  entiteType     String // nom du modèle : 'Membre' | 'Contribution' | … | 'Conflit'
  entiteId       String
  action         ActionAudit
  acteurId       String? // null = écriture système (seed, migration…)
  acteur         Utilisateur? @relation("AuditActeur", fields: [acteurId], references: [id], onDelete: SetNull)
  donneesAvant   Json? // snapshot avant (null pour CREATE) — passwordHash exclu
  donneesApres   Json? // snapshot après (null pour DELETE) — passwordHash exclu
  dateAction     DateTime     @default(now())

  @@index([entiteType, entiteId])
  @@index([acteurId])
  @@index([dateAction])
  @@index([organisationId])
}

// ---------------------------------------------------------------------------
// V2 (§5) — Notifications in-app. Canal interne uniquement (pas d'email).
// Périmètre initial : événements financiers (VERSEMENT_RECU, COTISATION_RETARD).
// Seuls les Utilisateur liés à un Membre peuvent en recevoir (cf. §4.5) — un membre
// sans compte ne notifie personne. `entiteType`/`entiteId` lient la notif à l'entité
// concernée (Versement / Contribution) sans FK dure (souple, comme AuditLog).
// ---------------------------------------------------------------------------

enum TypeNotification {
  VERSEMENT_RECU
  COTISATION_RETARD
}

model Notification {
  id             String           @id @default(uuid())
  organisationId String
  organisation   Organisation     @relation(fields: [organisationId], references: [id])
  destinataireId String
  destinataire   Utilisateur      @relation("NotificationDestinataire", fields: [destinataireId], references: [id], onDelete: Cascade)
  type           TypeNotification
  titre          String
  message        String
  entiteType     String? // ex. 'Versement' | 'Contribution' (pas de FK dure)
  entiteId       String?
  lu             Boolean          @default(false)
  dateCreation   DateTime         @default(now())
  dateLecture    DateTime? // renseignée au passage lu = true

  @@index([destinataireId, lu])
  @@index([destinataireId, type, dateCreation]) // pour l'anti-spam COTISATION_RETARD (< 7 j)
  @@index([organisationId])
}

// ---------------------------------------------------------------------------
// Trésorerie / dépenses (§5) — SORTIES de caisse, en regard des Versements (entrées).
//
// Workflow d'approbation : BROUILLON → EN_ATTENTE → APPROUVEE | REJETEE → PAYEE.
// SOLDE DE CAISSE = Σ Versements − Σ Dépenses (APPROUVEE + PAYEE) — cf. tresorerie.service.
// Modèle SCOPÉ (organisationId) + audité. Écritures en FK SCALAIRES (extension d'isolation).
// ---------------------------------------------------------------------------

enum StatutDepense {
  BROUILLON
  EN_ATTENTE
  APPROUVEE
  REJETEE
  PAYEE
}

enum CategorieDepense {
  AIDE_MEMBRE
  FUNERAILLES
  EVENEMENT
  FONCTIONNEMENT
  AUTRE
}

model Depense {
  id                   String           @id @default(uuid())
  organisationId       String
  organisation         Organisation     @relation(fields: [organisationId], references: [id])
  montant              Int
  date                 DateTime
  description          String
  categorie            CategorieDepense @default(AUTRE)
  statut               StatutDepense    @default(BROUILLON)
  // Bénéficiaire optionnel (ex. aide à un membre). Relation non contrainte au cycle de vie.
  beneficiaireMembreId String?
  beneficiaireMembre   Membre?          @relation("DepenseBeneficiaire", fields: [beneficiaireMembreId], references: [id])
  // Auteur de la saisie (obligatoire) et approbateur (renseigné à l'approbation/rejet).
  saisiParId           String
  saisiPar             Utilisateur      @relation("DepenseSaisiPar", fields: [saisiParId], references: [id])
  approuveParId        String?
  approuvePar          Utilisateur?     @relation("DepenseApprouvePar", fields: [approuveParId], references: [id])
  motifRejet           String?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  @@index([organisationId, statut])
  @@index([organisationId, date])
}

/* -------------------------------------------------------------------------- */
/* Cagnottes d'événement (§4.9) — collectes ponctuelles (deuil, mariage,       */
/* naissance…). POCHE SÉPARÉE de la caisse générale : dons des membres →        */
/* reversement au bénéficiaire. Modèles SCOPÉS (isolation tenant).             */
/* -------------------------------------------------------------------------- */

enum TypeCagnotte {
  DEUIL
  MARIAGE
  NAISSANCE
  AUTRE
}

enum StatutCagnotte {
  OUVERTE
  CLOTUREE
}

model CagnotteEvenement {
  id                   String         @id @default(uuid())
  organisationId       String
  organisation         Organisation   @relation(fields: [organisationId], references: [id])
  titre                String
  type                 TypeCagnotte   @default(AUTRE)
  description          String?
  objectif             Int? // montant cible optionnel (barre de progression)
  dateEvenement        DateTime?
  statut               StatutCagnotte @default(OUVERTE)
  // Bénéficiaire : un membre OU un nom libre (personne extérieure). ON DELETE SET NULL.
  beneficiaireMembreId String?
  beneficiaireMembre   Membre?        @relation("CagnotteBeneficiaire", fields: [beneficiaireMembreId], references: [id], onDelete: SetNull)
  beneficiaireNom      String?
  // Reversement au bénéficiaire (poche séparée : Σ dons − reversé = solde restant).
  montantReverse       Int            @default(0)
  dateReversement      DateTime?
  creeParId            String // auteur de la création (FK scalaire, pas de relation inverse)
  dons                 DonCagnotte[]
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  @@index([organisationId, statut])
  @@index([organisationId, type])
}

model DonCagnotte {
  id             String            @id @default(uuid())
  organisationId String
  organisation   Organisation      @relation(fields: [organisationId], references: [id])
  cagnotteId     String
  cagnotte       CagnotteEvenement @relation(fields: [cagnotteId], references: [id], onDelete: Cascade)
  // Donateur = membre de l'association (suivi par membre).
  membreId       String
  membre         Membre            @relation("DonCagnotteMembre", fields: [membreId], references: [id])
  montant        Int
  date           DateTime
  mode           ModeVersement     @default(ESPECES)
  note           String?
  saisiParId     String // FK scalaire (auteur de la saisie)
  createdAt      DateTime          @default(now())

  @@index([organisationId, cagnotteId])
}

/* -------------------------------------------------------------------------- */
/* Amendes / pénalités (§4.10) — sanctions financières (retard de cotisation,  */
/* absence aux réunions, autre). Saisie MANUELLE par le bureau. Poche de suivi */
/* SÉPARÉE (n'affecte pas encore le solde de trésorerie générale). SCOPÉE.     */
/* -------------------------------------------------------------------------- */

enum TypeAmende {
  RETARD_COTISATION
  ABSENCE_REUNION
  AUTRE
}

enum StatutAmende {
  IMPAYEE
  PAYEE
  ANNULEE
}

model Amende {
  id             String         @id @default(uuid())
  organisationId String
  organisation   Organisation   @relation(fields: [organisationId], references: [id])
  membreId       String
  membre         Membre         @relation("AmendeMembre", fields: [membreId], references: [id])
  type           TypeAmende     @default(AUTRE)
  motif          String
  montant        Int
  dateAmende     DateTime
  statut         StatutAmende   @default(IMPAYEE)
  datePaiement   DateTime?
  modePaiement   ModeVersement?
  creeParId      String // auteur de la saisie (FK scalaire)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([organisationId, statut])
  @@index([organisationId, membreId])
}
